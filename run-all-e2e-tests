#!/usr/bin/env bash
# Build and run the FAST Tamandua end-to-end test suites (no model tokens).
#
# This is the default e2e entry point. It runs BOTH fast tiers:
#
#   1. Smoke / state-machine test — manually advances workflow steps using
#      step claim/step complete with canned outputs. No agents, models, or
#      schedulers. (~10-15 seconds)
#   2. Scripted-agent full-pipeline test — REAL daemon + scheduler + worktree
#      + merge pipeline driven by a deterministic scripted agent standing in
#      for pi (TAMANDUA_PI_BINARY). No models, ZERO tokens. (~30-60 seconds)
#
# For the SLOW REAL end-to-end test that runs actual agent invocations:
#   ./run-all-real-e2e-tests
# That test spends real model tokens, takes 30+ minutes, and should only
# be run deliberately.
#
# To run a single tier explicitly:
#   ./run-all-smoke-e2e-tests
#   ./run-all-scripted-e2e-tests
#
# Output is streamed to the terminal AND tee'd to a log file for inspection.
# Exit code is non-zero if either suite fails.
set -euo pipefail
cd "$(dirname "$0")"

LOG="${TAMANDUA_E2E_TEST_LOG:-e2e-test-output.log}"

npm run build
node --test e2e-tests/workflows-smoke.test.ts e2e-tests/workflows-scripted.test.ts e2e-tests/workflows-scripted-hermes.test.ts e2e-tests/autoresearch-scripted.test.ts e2e-tests/fixture-health.test.ts 2>&1 | tee "$LOG"
exit "${PIPESTATUS[1]}"
