#!/usr/bin/env bash
##############################################################################
# REAL HERMES E2E CANARY — spends a SMALL amount of real model tokens
##############################################################################
# Runs ONE do-now workflow with a trivial task through the real
# daemon → scheduler → hermes pipeline and audits token accounting
# (session_id trailer → state.db token lookup).
#
# This validates the FULL hermes pipeline against the REAL hermes binary,
# catching hermes-side breakage (session_id trailer format, state.db schema)
# before a production run does.
#
# COST/TIME:
#   - Real API tokens for one trivial agent round
#   - Expected runtime: 30+ minutes (hermes is very slow)
#
# When to use:
#   - At hermes-upgrade milestones, to confirm the session_id trailer and
#     state.db token accounting still work end-to-end
#   - NEVER part of ./run-all-e2e-tests or npm test
#   - Opt-in only — run manually when hermes integration needs validation
#
# Agents: DO NOT run this by default. Only run when explicitly asked.
##############################################################################
# Output is streamed to the terminal AND tee'd to a log file for inspection.
# Exit code matches the underlying `node --test` exit code.
set -euo pipefail
cd "$(dirname "$0")"

LOG="${canarinho_HERMES_CANARY_E2E_LOG:-e2e-hermes-canary-test-output.log}"

npm run build
node --test e2e-tests/workflows-hermes-canary-real.test.ts 2>&1 | tee "$LOG"
exit "${PIPESTATUS[1]}"
